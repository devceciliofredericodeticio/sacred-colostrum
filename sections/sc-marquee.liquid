<div class="sc-marquee" style="background:{{ section.settings.bg_color }};padding:{{ section.settings.padding }}px 0;overflow:hidden;">
  <div class="sc-marquee__track">
    <div class="sc-marquee__inner">
      {%- for i in (1..8) -%}
        {%- for block in section.blocks -%}
          <span class="sc-marquee__item" style="color:{{ section.settings.text_color }};">
            {%- if block.settings.icon != blank -%}<img src="{{ block.settings.icon | image_url: width: 24 }}" alt="" width="24" height="24" style="vertical-align:middle;margin-right:8px;">{%- endif -%}
            {{ block.settings.text }}
          </span>
          <span class="sc-marquee__sep" style="color:{{ section.settings.sep_color }};">{{ section.settings.separator }}</span>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
</div>

<style>
.sc-marquee__track { overflow:hidden; }
.sc-marquee__inner { display:flex;align-items:center;white-space:nowrap;animation:sc-scroll {{ section.settings.speed }}s linear infinite; }
.sc-marquee__item { font-size:{{ section.settings.font_size }}px;font-weight:500;padding:0 16px;display:inline-flex;align-items:center; }
.sc-marquee__sep { padding:0 4px;opacity:.6; }
@keyframes sc-scroll { 0%{transform:translateX(0)} 100%{transform:translateX(-50%)} }
@media (max-width:600px) { .sc-marquee__item { font-size:{{ section.settings.font_size | minus: 2 }}px; } }
</style>

{% schema %}
{
  "name": "SC - Marquee",
  "tag": "section",
  "max_blocks": 10,
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#f5f5f5" },
    { "type": "color", "id": "text_color", "label": "Text Color", "default": "#111111" },
    { "type": "color", "id": "sep_color", "label": "Separator Color", "default": "#999999" },
    { "type": "text", "id": "separator", "label": "Separator", "default": "✦" },
    { "type": "range", "id": "font_size", "label": "Font Size (px)", "min": 12, "max": 20, "step": 1, "default": 14 },
    { "type": "range", "id": "padding", "label": "Vertical Padding (px)", "min": 8, "max": 40, "step": 4, "default": 16 },
    { "type": "range", "id": "speed", "label": "Scroll Speed (seconds)", "min": 10, "max": 60, "step": 5, "default": 30 }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Marquee Item",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "100% Grass-Fed Colostrum" },
        { "type": "image_picker", "id": "icon", "label": "Icon (optional)" }
      ]
    }
  ],
  "presets": [{ "name": "SC - Marquee", "blocks": [
    { "type": "item", "settings": { "text": "100% Grass-Fed" } },
    { "type": "item", "settings": { "text": "Third-Party Tested" } },
    { "type": "item", "settings": { "text": "No Fillers" } },
    { "type": "item", "settings": { "text": "60-Day Guarantee" } }
  ]}]
}
{% endschema %}
