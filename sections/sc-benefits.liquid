<div class="sc-benefits" style="background:{{ section.settings.bg_color }};padding:{{ section.settings.pad_v }}px 0;">
  <div class="sc-benefits__inner">
    {%- if section.settings.heading != blank -%}
      <div class="sc-benefits__head">
        <h2 class="sc-benefits__title" style="color:{{ section.settings.heading_color }};">{{ section.settings.heading }}</h2>
        {%- if section.settings.subtext != blank -%}
          <p class="sc-benefits__sub" style="color:{{ section.settings.text_color }};">{{ section.settings.subtext }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}
    <div class="sc-benefits__grid">
      {%- for block in section.blocks -%}
        <div class="sc-benefits__item" {{ block.shopify_attributes }}>
          <div class="sc-benefits__item-head">
            {%- if block.settings.icon != blank -%}
              <img src="{{ block.settings.icon | image_url: width: 48 }}" alt="" width="24" height="24">
            {%- endif -%}
            <span class="sc-benefits__label" style="color:{{ section.settings.heading_color }};">{{ block.settings.label }}</span>
          </div>
          {%- if block.settings.title != blank -%}
            <h3 class="sc-benefits__name" style="color:{{ section.settings.heading_color }};">{{ block.settings.title }}</h3>
          {%- endif -%}
          {%- if block.settings.text != blank -%}
            <p class="sc-benefits__text" style="color:{{ section.settings.text_color }};">{{ block.settings.text }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
    {%- if section.settings.button_label != blank -%}
      <div class="sc-benefits__cta">
        <a href="{{ section.settings.button_url }}" class="sc-btn-outline" style="border-color:{{ section.settings.heading_color }};color:{{ section.settings.heading_color }};">
          {{ section.settings.button_label }}
        </a>
      </div>
    {%- endif -%}
  </div>
</div>

<style>
.sc-benefits { width:100%; }
.sc-benefits__inner { max-width:1440px;margin:0 auto;padding:0 80px; }
.sc-benefits__head { text-align:center;margin-bottom:56px; }
.sc-benefits__title { font-size:clamp(28px,3vw,48px);font-weight:700;margin:0 0 16px; }
.sc-benefits__sub { font-size:16px;max-width:529px;margin:0 auto;line-height:1.6; }
.sc-benefits__grid { display:grid;grid-template-columns:repeat(2,1fr);gap:0; }
.sc-benefits__item { padding:28px 0;border-bottom:1px solid rgba(0,0,0,.1); }
.sc-benefits__item-head { display:flex;align-items:center;gap:12px;margin-bottom:8px; }
.sc-benefits__label { font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.08em; }
.sc-benefits__name { font-size:18px;font-weight:600;margin:0 0 8px; }
.sc-benefits__text { font-size:15px;line-height:1.6;margin:0; }
.sc-benefits__cta { text-align:center;margin-top:56px; }
.sc-btn-outline { display:inline-block;padding:15px 40px;border:2px solid;text-decoration:none;font-weight:600;font-size:16px;border-radius:4px;transition:all .2s; }
.sc-btn-outline:hover { background:currentColor; }
@media (max-width:900px) {
  .sc-benefits__inner { padding:0 32px; }
  .sc-benefits__grid { grid-template-columns:1fr; }
}
@media (max-width:600px) {
  .sc-benefits__inner { padding:0 20px; }
}
</style>

{% schema %}
{
  "name": "SC - Benefits Grid",
  "tag": "section",
  "max_blocks": 12,
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#ffffff" },
    { "type": "color", "id": "heading_color", "label": "Heading Color", "default": "#111111" },
    { "type": "color", "id": "text_color", "label": "Text Color", "default": "#555555" },
    { "type": "range", "id": "pad_v", "label": "Vertical Padding (px)", "min": 40, "max": 160, "step": 8, "default": 80 },
    { "type": "text", "id": "heading", "label": "Section Heading" },
    { "type": "textarea", "id": "subtext", "label": "Section Subtext" },
    { "type": "text", "id": "button_label", "label": "Button Label" },
    { "type": "url", "id": "button_url", "label": "Button URL" }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        { "type": "image_picker", "id": "icon", "label": "Icon" },
        { "type": "text", "id": "label", "label": "Label Tag", "default": "Benefit" },
        { "type": "text", "id": "title", "label": "Title", "default": "Benefit Title" },
        { "type": "textarea", "id": "text", "label": "Description" }
      ]
    }
  ],
  "presets": [{ "name": "SC - Benefits Grid" }]
}
{% endschema %}
