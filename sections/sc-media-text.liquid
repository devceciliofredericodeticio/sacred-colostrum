<div class="sc-media-text" style="background:{{ section.settings.bg_color }};padding:{{ section.settings.pad_v }}px 0;">
  <div class="sc-media-text__inner sc-media-text__inner--{{ section.settings.layout }}">
    <div class="sc-media-text__media">
      {%- if section.settings.image != blank -%}
        <img src="{{ section.settings.image | image_url: width: 1000 }}" alt="{{ section.settings.image.alt }}" loading="lazy" style="width:100%;height:100%;object-fit:cover;border-radius:{{ section.settings.img_radius }}px;">
      {%- else -%}
        <div style="width:100%;aspect-ratio:3/4;background:#e8e8e8;border-radius:{{ section.settings.img_radius }}px;"></div>
      {%- endif -%}
    </div>
    <div class="sc-media-text__content">
      {%- if section.settings.heading != blank -%}
        <h2 class="sc-media-text__title" style="color:{{ section.settings.heading_color }};">{{ section.settings.heading }}</h2>
      {%- endif -%}
      <div class="sc-media-text__accordions">
        {%- for block in section.blocks -%}
          <details class="sc-accordion" {{ block.shopify_attributes }}>
            <summary class="sc-accordion__q" style="color:{{ section.settings.heading_color }};">
              <span>{{ block.settings.title }}</span>
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <div class="sc-accordion__body" style="color:{{ section.settings.text_color }};">{{ block.settings.content }}</div>
          </details>
        {%- endfor -%}
      </div>
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_url }}" class="sc-btn-solid" style="background:{{ section.settings.heading_color }};color:{{ section.settings.bg_color }};margin-top:40px;display:inline-block;">
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</div>

<style>
.sc-media-text { width:100%; }
.sc-media-text__inner { max-width:1440px;margin:0 auto;padding:0 0 0 0;display:grid;grid-template-columns:1fr 1fr;min-height:600px; }
.sc-media-text__inner--right .sc-media-text__media { order:2; }
.sc-media-text__inner--right .sc-media-text__content { order:1; }
.sc-media-text__media { overflow:hidden; }
.sc-media-text__content { padding:112px 80px 112px 80px; }
.sc-media-text__title { font-size:clamp(28px,3vw,48px);font-weight:700;margin:0 0 40px;line-height:1.2; }
.sc-accordion { border-bottom:1px solid rgba(0,0,0,.12); }
.sc-accordion__q { display:flex;align-items:center;justify-content:space-between;padding:22px 0;cursor:pointer;font-size:16px;font-weight:600;list-style:none;gap:16px; }
.sc-accordion__q::-webkit-details-marker { display:none; }
.sc-accordion__q svg { flex-shrink:0;transition:transform .2s; }
details[open] .sc-accordion__q svg { transform:rotate(180deg); }
.sc-accordion__body { padding:0 0 22px;font-size:15px;line-height:1.7; }
@media (max-width:900px) {
  .sc-media-text__inner { grid-template-columns:1fr; }
  .sc-media-text__inner--right .sc-media-text__media { order:1; }
  .sc-media-text__inner--right .sc-media-text__content { order:2; }
  .sc-media-text__content { padding:60px 32px; }
  .sc-media-text__media { max-height:500px; }
}
@media (max-width:600px) {
  .sc-media-text__content { padding:48px 20px; }
  .sc-media-text__media { max-height:350px; }
}
</style>

{% schema %}
{
  "name": "SC - Media + Text",
  "tag": "section",
  "max_blocks": 8,
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#ffffff" },
    { "type": "color", "id": "heading_color", "label": "Heading Color", "default": "#111111" },
    { "type": "color", "id": "text_color", "label": "Text Color", "default": "#555555" },
    { "type": "range", "id": "pad_v", "label": "Vertical Padding", "min": 0, "max": 160, "step": 8, "default": 0 },
    { "type": "range", "id": "img_radius", "label": "Image Border Radius", "min": 0, "max": 32, "step": 4, "default": 0 },
    { "type": "select", "id": "layout", "label": "Image Position", "options": [{"value":"left","label":"Left"},{"value":"right","label":"Right"}], "default": "left" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "text", "id": "button_label", "label": "Button Label" },
    { "type": "url", "id": "button_url", "label": "Button URL" }
  ],
  "blocks": [
    {
      "type": "accordion",
      "name": "Accordion Item",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "What is colostrum?" },
        { "type": "richtext", "id": "content", "label": "Content", "default": "<p>Colostrum is nature's first food...</p>" }
      ]
    }
  ],
  "presets": [{ "name": "SC - Media + Text" }]
}
{% endschema %}
