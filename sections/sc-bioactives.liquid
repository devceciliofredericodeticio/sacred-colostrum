<div class="sc-bioactives" style="background:{{ section.settings.bg_color }};padding:{{ section.settings.pad_v }}px 0;">
  <div class="sc-bioactives__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="sc-bioactives__title" style="color:{{ section.settings.heading_color }};">{{ section.settings.heading }}</h2>
    {%- endif -%}
    <div class="sc-bioactives__layout">
      <div class="sc-bioactives__cloud-wrap">
        {%- if section.settings.product_image != blank -%}
          <img src="{{ section.settings.product_image | image_url: width: 600 }}" alt="" class="sc-bioactives__product-img" loading="lazy">
        {%- else -%}
          <div class="sc-bioactives__product-placeholder"></div>
        {%- endif -%}
        <div class="sc-bioactives__tags">
          {%- for block in section.blocks -%}
            {%- if block.type == 'bioactive' -%}
              <span class="sc-bioactives__tag" style="font-size:{{ block.settings.size }}px;color:{{ section.settings.tag_color }};opacity:{{ block.settings.opacity | divided_by: 100.0 }};" {{ block.shopify_attributes }}>
                {{ block.settings.name }}
              </span>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
      <div class="sc-bioactives__detail">
        {%- if section.settings.detail_heading != blank -%}
          <h3 class="sc-bioactives__detail-title" style="color:{{ section.settings.heading_color }};">{{ section.settings.detail_heading }}</h3>
        {%- endif -%}
        <div class="sc-bioactives__accordions">
          {%- for block in section.blocks -%}
            {%- if block.type == 'ingredient' -%}
              <details class="sc-accordion" {{ block.shopify_attributes }}>
                <summary class="sc-accordion__q" style="color:{{ section.settings.heading_color }};">
                  <span>{{ block.settings.title }}</span>
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                </summary>
                <div class="sc-accordion__body" style="color:{{ section.settings.text_color }};">{{ block.settings.content }}</div>
              </details>
            {%- endif -%}
          {%- endfor -%}
        </div>
        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_url }}" class="sc-btn-solid" style="background:{{ section.settings.heading_color }};color:{{ section.settings.bg_color }};margin-top:40px;display:inline-block;">
            {{ section.settings.button_label }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

<style>
.sc-bioactives { width:100%; }
.sc-bioactives__inner { max-width:1440px;margin:0 auto;padding:0 64px; }
.sc-bioactives__title { font-size:clamp(28px,3vw,48px);font-weight:700;margin:0 0 56px;text-align:center; }
.sc-bioactives__layout { display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:start; }
.sc-bioactives__cloud-wrap { position:relative;min-height:500px;display:flex;align-items:center;justify-content:center; }
.sc-bioactives__product-img { width:70%;max-width:350px;position:relative;z-index:2;display:block;margin:0 auto; }
.sc-bioactives__product-placeholder { width:288px;height:399px;background:#e8e8e8;border-radius:8px;margin:0 auto; }
.sc-bioactives__tags { position:absolute;inset:0;display:flex;flex-wrap:wrap;align-items:center;justify-content:center;gap:8px;pointer-events:none; }
.sc-bioactives__tag { font-weight:600;letter-spacing:.02em;white-space:nowrap;padding:4px 8px; }
.sc-bioactives__detail { padding-top:40px; }
.sc-bioactives__detail-title { font-size:clamp(22px,2vw,36px);font-weight:700;margin:0 0 32px;line-height:1.2; }
.sc-accordion { border-bottom:1px solid rgba(0,0,0,.12); }
.sc-accordion__q { display:flex;align-items:center;justify-content:space-between;padding:22px 0;cursor:pointer;font-size:16px;font-weight:600;list-style:none;gap:16px; }
.sc-accordion__q::-webkit-details-marker { display:none; }
.sc-accordion__q svg { flex-shrink:0;transition:transform .2s; }
details[open] .sc-accordion__q svg { transform:rotate(180deg); }
.sc-accordion__body { padding:0 0 22px;font-size:15px;line-height:1.7; }
@media (max-width:900px) {
  .sc-bioactives__inner { padding:0 32px; }
  .sc-bioactives__layout { grid-template-columns:1fr;gap:48px; }
  .sc-bioactives__cloud-wrap { min-height:350px; }
}
@media (max-width:600px) {
  .sc-bioactives__inner { padding:0 20px; }
  .sc-bioactives__cloud-wrap { min-height:280px; }
}
</style>

{% schema %}
{
  "name": "SC - Bioactives",
  "tag": "section",
  "max_blocks": 30,
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#ffffff" },
    { "type": "color", "id": "heading_color", "label": "Heading Color", "default": "#111111" },
    { "type": "color", "id": "text_color", "label": "Text Color", "default": "#555555" },
    { "type": "color", "id": "tag_color", "label": "Tag Color", "default": "#111111" },
    { "type": "range", "id": "pad_v", "label": "Vertical Padding", "min": 40, "max": 160, "step": 8, "default": 80 },
    { "type": "image_picker", "id": "product_image", "label": "Product Image" },
    { "type": "text", "id": "heading", "label": "Section Heading", "default": "What's Inside" },
    { "type": "text", "id": "detail_heading", "label": "Detail Panel Heading", "default": "Key Bioactives Explained" },
    { "type": "text", "id": "button_label", "label": "Button Label" },
    { "type": "url", "id": "button_url", "label": "Button URL" }
  ],
  "blocks": [
    {
      "type": "bioactive",
      "name": "Bioactive Tag",
      "settings": [
        { "type": "text", "id": "name", "label": "Name", "default": "IgG" },
        { "type": "range", "id": "size", "label": "Font Size (px)", "min": 10, "max": 22, "step": 1, "default": 14 },
        { "type": "range", "id": "opacity", "label": "Opacity (%)", "min": 30, "max": 100, "step": 5, "default": 80 }
      ]
    },
    {
      "type": "ingredient",
      "name": "Ingredient Accordion",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Immunoglobulins (IgG, IgA, IgM)" },
        { "type": "richtext", "id": "content", "label": "Content", "default": "<p>Immunoglobulins are the primary immune proteins in colostrum...</p>" }
      ]
    }
  ],
  "presets": [{ "name": "SC - Bioactives" }]
}
{% endschema %}
