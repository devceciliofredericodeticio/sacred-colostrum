<div class="sc-testimonials" style="background:{{ section.settings.bg_color }};padding:{{ section.settings.pad_v }}px 0;">
  <div class="sc-testimonials__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="sc-testimonials__title" style="color:{{ section.settings.heading_color }};">{{ section.settings.heading }}</h2>
    {%- endif -%}
    <div class="sc-testimonials__slider" id="sc-slider-{{ section.id }}">
      <div class="sc-testimonials__track">
        {%- for block in section.blocks -%}
          <div class="sc-testimonials__slide" {{ block.shopify_attributes }}>
            <div class="sc-testimonials__stars">
              {%- for i in (1..5) -%}★{%- endfor -%}
            </div>
            <p class="sc-testimonials__quote" style="color:{{ section.settings.text_color }};">"{{ block.settings.quote }}"</p>
            <div class="sc-testimonials__author" style="color:{{ section.settings.heading_color }};">
              {%- if block.settings.avatar != blank -%}
                <img src="{{ block.settings.avatar | image_url: width: 48 }}" alt="{{ block.settings.name }}" width="48" height="48" style="border-radius:50%;">
              {%- endif -%}
              <div>
                <strong>{{ block.settings.name }}</strong>
                {%- if block.settings.subtitle != blank -%}<br><span>{{ block.settings.subtitle }}</span>{%- endif -%}
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>
      <div class="sc-testimonials__nav">
        <button class="sc-slider-prev" aria-label="Previous">&#8592;</button>
        <button class="sc-slider-next" aria-label="Next">&#8594;</button>
      </div>
    </div>
    {%- if section.settings.button_label != blank -%}
      <div style="text-align:center;margin-top:48px;">
        <a href="{{ section.settings.button_url }}" class="sc-btn-outline" style="border-color:{{ section.settings.heading_color }};color:{{ section.settings.heading_color }};">
          {{ section.settings.button_label }}
        </a>
      </div>
    {%- endif -%}
  </div>
</div>

<style>
.sc-testimonials { width:100%; }
.sc-testimonials__inner { max-width:1440px;margin:0 auto;padding:0 80px; }
.sc-testimonials__title { font-size:clamp(28px,3vw,48px);font-weight:700;margin:0 0 48px; }
.sc-testimonials__slider { position:relative;overflow:hidden; }
.sc-testimonials__track { display:flex;transition:transform .4s ease;gap:24px; }
.sc-testimonials__slide { flex:0 0 calc(33.333% - 16px);background:#f9f9f9;border-radius:8px;padding:40px 32px; }
.sc-testimonials__stars { color:#f5a623;font-size:18px;margin-bottom:16px; }
.sc-testimonials__quote { font-size:16px;line-height:1.7;margin:0 0 24px; }
.sc-testimonials__author { display:flex;align-items:center;gap:12px;font-size:14px; }
.sc-testimonials__nav { display:flex;gap:12px;justify-content:flex-end;margin-top:24px; }
.sc-slider-prev,.sc-slider-next { width:40px;height:40px;border:1px solid #ddd;background:#fff;cursor:pointer;font-size:18px;border-radius:4px;display:flex;align-items:center;justify-content:center; }
.sc-slider-prev:hover,.sc-slider-next:hover { background:#111;color:#fff; }
@media (max-width:900px) {
  .sc-testimonials__inner { padding:0 32px; }
  .sc-testimonials__slide { flex:0 0 calc(50% - 12px); }
}
@media (max-width:600px) {
  .sc-testimonials__inner { padding:0 20px; }
  .sc-testimonials__slide { flex:0 0 100%; }
}
</style>
<script>
(function(){
  var el = document.getElementById('sc-slider-{{ section.id }}');
  if(!el) return;
  var track = el.querySelector('.sc-testimonials__track');
  var slides = track.querySelectorAll('.sc-testimonials__slide');
  var idx = 0;
  function visible() { return window.innerWidth <= 600 ? 1 : window.innerWidth <= 900 ? 2 : 3; }
  function go(n) {
    var max = Math.max(0, slides.length - visible());
    idx = Math.min(Math.max(0, n), max);
    var w = slides[0].offsetWidth + 24;
    track.style.transform = 'translateX(-' + (idx * w) + 'px)';
  }
  el.querySelector('.sc-slider-next').addEventListener('click', function(){ go(idx + 1); });
  el.querySelector('.sc-slider-prev').addEventListener('click', function(){ go(idx - 1); });
  window.addEventListener('resize', function(){ go(idx); });
})();
</script>

{% schema %}
{
  "name": "SC - Testimonials",
  "tag": "section",
  "max_blocks": 12,
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#ffffff" },
    { "type": "color", "id": "heading_color", "label": "Heading Color", "default": "#111111" },
    { "type": "color", "id": "text_color", "label": "Text Color", "default": "#555555" },
    { "type": "range", "id": "pad_v", "label": "Vertical Padding (px)", "min": 40, "max": 160, "step": 8, "default": 80 },
    { "type": "text", "id": "heading", "label": "Heading", "default": "What our customers say" },
    { "type": "text", "id": "button_label", "label": "Button Label" },
    { "type": "url", "id": "button_url", "label": "Button URL" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "textarea", "id": "quote", "label": "Quote", "default": "Amazing product, changed my life!" },
        { "type": "text", "id": "name", "label": "Customer Name", "default": "Jane D." },
        { "type": "text", "id": "subtitle", "label": "Subtitle / Location" },
        { "type": "image_picker", "id": "avatar", "label": "Avatar Image" }
      ]
    }
  ],
  "presets": [{ "name": "SC - Testimonials" }]
}
{% endschema %}
