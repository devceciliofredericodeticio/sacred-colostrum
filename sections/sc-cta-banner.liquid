<div class="sc-cta" style="background:{{ section.settings.bg_color }};padding:{{ section.settings.pad_v }}px 0;">
  {%- if section.settings.bg_image != blank -%}
    <div style="position:absolute;inset:0;"><img src="{{ section.settings.bg_image | image_url: width: 2000 }}" alt="" style="width:100%;height:100%;object-fit:cover;"></div>
    <div style="position:absolute;inset:0;background:rgba(0,0,0,{{ section.settings.overlay_opacity | divided_by: 100.0 }});"></div>
  {%- endif -%}
  <div class="sc-cta__inner" style="position:relative;z-index:2;">
    {%- if section.settings.heading != blank -%}
      <h2 class="sc-cta__title" style="color:{{ section.settings.text_color }};">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subtext != blank -%}
      <p class="sc-cta__sub" style="color:{{ section.settings.text_color }};">{{ section.settings.subtext }}</p>
    {%- endif -%}
    <div class="sc-cta__btns">
      {%- if section.settings.btn1_label != blank -%}
        <a href="{{ section.settings.btn1_url }}" class="sc-btn-solid" style="background:{{ section.settings.btn1_bg }};color:{{ section.settings.btn1_text }};">{{ section.settings.btn1_label }}</a>
      {%- endif -%}
      {%- if section.settings.btn2_label != blank -%}
        <a href="{{ section.settings.btn2_url }}" style="color:{{ section.settings.text_color }};text-decoration:underline;font-weight:600;font-size:16px;padding:16px 0;">{{ section.settings.btn2_label }}</a>
      {%- endif -%}
    </div>
  </div>
</div>
<style>
.sc-cta { width:100%;position:relative;overflow:hidden; }
.sc-cta__inner { max-width:1440px;margin:0 auto;padding:0 80px;display:flex;flex-direction:column;align-items:flex-start;gap:0; }
.sc-cta--center .sc-cta__inner { align-items:center;text-align:center; }
.sc-cta__title { font-size:clamp(32px,4vw,64px);font-weight:700;line-height:1.1;margin:0 0 24px;max-width:610px; }
.sc-cta__sub { font-size:16px;line-height:1.6;margin:0 0 40px;max-width:610px; }
.sc-cta__btns { display:flex;align-items:center;gap:32px;flex-wrap:wrap; }
@media (max-width:900px) { .sc-cta__inner { padding:0 32px; } }
@media (max-width:600px) { .sc-cta__inner { padding:0 20px; } .sc-cta__btns { flex-direction:column;gap:16px;align-items:flex-start; } }
</style>
{% schema %}
{
  "name": "SC - CTA Banner",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "bg_image", "label": "Background Image" },
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#111111" },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay Opacity", "min": 0, "max": 80, "step": 5, "default": 0 },
    { "type": "color", "id": "text_color", "label": "Text Color", "default": "#ffffff" },
    { "type": "range", "id": "pad_v", "label": "Vertical Padding (px)", "min": 60, "max": 200, "step": 8, "default": 106 },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Start your wellness journey today" },
    { "type": "textarea", "id": "subtext", "label": "Subtext" },
    { "type": "text", "id": "btn1_label", "label": "Primary Button Label", "default": "Shop Now" },
    { "type": "url", "id": "btn1_url", "label": "Primary Button URL" },
    { "type": "color", "id": "btn1_bg", "label": "Primary Button BG", "default": "#ffffff" },
    { "type": "color", "id": "btn1_text", "label": "Primary Button Text", "default": "#111111" },
    { "type": "text", "id": "btn2_label", "label": "Secondary Link Label" },
    { "type": "url", "id": "btn2_url", "label": "Secondary Link URL" }
  ],
  "presets": [{ "name": "SC - CTA Banner" }]
}
{% endschema %}
